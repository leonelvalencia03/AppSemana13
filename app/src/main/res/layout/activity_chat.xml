<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chat_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_background"
    android:orientation="vertical">

    <!-- Encabezado del chat: navegación, avatar y estado del contacto. -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="true"
            android:contentDescription="@string/desc_back"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_avatar_gabriel"
            android:gravity="center"
            android:text="IN"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Isaac Neftali"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En línea"
                android:textColor="@color/accent"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/desc_options"
            android:src="@android:drawable/ic_menu_more"
            android:tint="@color/text_primary" />
    </LinearLayout>

    <!-- Contenedor preparado para la conversación.
         Ya usa RecyclerView para que el equipo pueda conectar un Adapter y datos reales
         sin modificar la estructura visual actual. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:paddingHorizontal="16dp"
        android:paddingTop="18dp"
        android:scrollbars="none" />

    <!-- Barra inferior de entrada. Actualmente es visual; no envía mensajes todavía. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Escribe un mensaje..."
            android:textColor="@color/text_muted"
            android:textSize="16sp" />

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_send_button"
            android:contentDescription="@string/desc_send"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="@color/screen_background" />
    </LinearLayout>
</LinearLayout>
